# Local Postgres example:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/vibeventure?schema=public"
DATABASE_URL="postgresql://user:password@localhost:5432/vibeventure?schema=public"

PORT=5000

# S3 bucket that stores post cover images
S3_BUCKET_NAME=vibeventure-images-changeme
AWS_REGION=ap-southeast-1

# Comma-free single origin, or "*" for local dev
CORS_ORIGIN=http://localhost:5173
